# ── Core ──────────────────────────────────────────────────────────────────────
TERMINAL_PROJECT_NAME=Terminal
TERMINAL_BASE_API_URL=https://your-api-domain.com
TERMINAL_ADMIN_KEY=your_admin_key_here

# ── Server ────────────────────────────────────────────────────────────────────
TERMINAL_HOST=0.0.0.0
TERMINAL_PORT=8000
TERMINAL_ENVIRONMENT=local          # local | staging | production
TERMINAL_API_V1_STR=api/v1
TERMINAL_BACKEND_CORS_ORIGINS=[http://localhost:3000,http://localhost:8000,http://localhost:5173]

# ── Data providers ────────────────────────────────────────────────────────────
TERMINAL_EODHD_API_KEY=your_eodhd_api_key_here
TERMINAL_EODHD_API_BASE_URL=https://eodhd.com

TERMINAL_COINGECKO_API_KEY=your_coingecko_api_key_here
TERMINAL_COINGECKO_API_BASE_URL=https://api.coingecko.com

# ── Redis ─────────────────────────────────────────────────────────────────────
TERMINAL_REDIS_URL=redis://localhost:6379

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Paste the full service account credentials JSON as a single-line string
TERMINAL_GOOGLE_SHEETS_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/...","universe_domain":"googleapis.com"}'
TERMINAL_SYMBOLS_SPREADSHEET_ID=your_google_spreadsheet_id_here

# ── Cache TTLs (seconds) — all have sensible defaults, override as needed ─────

# Quotes
TERMINAL_REALTIME_QUOTE_CACHE_TTL=15
TERMINAL_US_QUOTE_DELAYED_CACHE_TTL=60
TERMINAL_MIXED_REAL_TIME_QUOTES_CACHE_TTL=15
TERMINAL_CRYPTO_REAL_TIME_QUOTES_CACHE_TTL=15
TERMINAL_CRYPTO_FUNDAMENTALS_CACHE_TTL=300
TERMINAL_INDEX_BASED_REAL_TIME_QUOTES_CACHE_TTL=30
TERMINAL_COMMODITY_BASED_REAL_TIME_QUOTES_CACHE_TTL=30
TERMINAL_FOREX_REAL_TIME_QUOTES_CACHE_TTL=15

# Historical / EOD
TERMINAL_HISTORICAL_EOD_CACHE_TTL=3600
TERMINAL_INTRADAY_CACHE_TTL=60
TERMINAL_GENERIC_EOD_CACHE_TTL=3600
TERMINAL_INDEX_BASED_HISTORICAL_EOD_CACHE_TTL=3600
TERMINAL_BOND_HISTORICAL_EOD_CACHE_TTL=3600

# CoinGecko
TERMINAL_COINGECKO_MARKET_CAP_CACHE_TTL=3600
TERMINAL_COINGECKO_TOKEN_PRICE_CACHE_TTL=3600
TERMINAL_COINGECKO_TOKEN_INFO_CACHE_TTL=3600

# News / Screener / Insider
TERMINAL_NEWS_CACHE_TTL=300
TERMINAL_SCREENER_CACHE_TTL=300
TERMINAL_INSIDER_TRANSACTIONS_CACHE_TTL=3600

# Calendars
TERMINAL_EARNINGS_CALENDAR_CACHE_TTL=3600
TERMINAL_DIVIDEND_CALENDAR_CACHE_TTL=3600
TERMINAL_SPLIT_CALENDAR_CACHE_TTL=3600
TERMINAL_IPO_CALENDAR_CACHE_TTL=3600
TERMINAL_ECONOMIC_CALENDAR_CACHE_TTL=1800

# Fundamentals
TERMINAL_FUNDAMENTAL_DEFAULT_CACHE_TTL=3600
TERMINAL_FUNDAMENTAL_GENERAL_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_HIGHLIGHTS_CACHE_TTL=3600
TERMINAL_FUNDAMENTAL_SHARES_STATS_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_VALUATION_CACHE_TTL=3600
TERMINAL_FUNDAMENTAL_TECHNICALS_CACHE_TTL=3600
TERMINAL_FUNDAMENTAL_ANALYST_RATINGS_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_EARNINGS_HISTORY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_EARNINGS_TREND_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_INCOME_STATEMENT_YEARLY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_INCOME_STATEMENT_QUARTERLY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_BALANCE_SHEET_YEARLY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_BALANCE_SHEET_QUARTERLY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_CASH_FLOW_YEARLY_CACHE_TTL=86400
TERMINAL_FUNDAMENTAL_CASH_FLOW_QUARTERLY_CACHE_TTL=86400
